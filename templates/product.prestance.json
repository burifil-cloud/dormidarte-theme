        "guarantee": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div style=\"display:flex;gap:12px;align-items:center;border:1px solid rgba(92,195,232,.5);border-radius:14px;padding:14px 16px;margin-top:14px;background:rgba(92,195,232,.12)\"><span style=\"font-size:26px;line-height:1\">🌙</span><span style=\"font-size:1.4rem;line-height:1.4\"><strong>30 noches de prueba en casa.</strong> Si no es tu colchón, lo recogemos gratis y te devolvemos el 100%.</span></div>"
          }
        },
        "promo": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"cbundle\" data-colchon-variants='[{% for v in product.variants %}{\"id\":{{ v.id }},\"t\":{{ v.title | json }}}{% unless forloop.last %},{% endunless %}{% endfor %}]'>\n<p class=\"cbundle__head\"><span class=\"cbundle__ico\">🎁</span><span><strong>Colchón + canapé = 10% de descuento.</strong> Elige tu canapé y la medida; añadimos los dos al carrito y el 10% se aplica solo.</span></p>\n<div class=\"cbundle__step\">1 · Elige tu canapé</div>\n<div class=\"cbundle__canapes\">\n{% assign cbh = 'canape-noblia,canape-magna,canape-imperial' | split: ',' %}\n{% for h in cbh %}{% assign cp = all_products[h] %}{% if cp != blank %}\n<label class=\"cbundle__canape\">\n<input type=\"radio\" name=\"cbundle-canape\" value=\"{{ h }}\" data-variants='[{% for v in cp.variants %}{\"id\":{{ v.id }},\"t\":{{ v.title | json }},\"p\":{{ v.price | money | json }}}{% unless forloop.last %},{% endunless %}{% endfor %}]'{% if forloop.first %} checked{% endif %}>\n<span class=\"cbundle__canape-media\">{% if cp.featured_image != blank %}<img src=\"{{ cp.featured_image | image_url: width: 260 }}\" alt=\"{{ cp.title | escape }}\" loading=\"lazy\">{% endif %}</span>\n<span class=\"cbundle__canape-name\">{{ cp.title | remove: 'Canapé ' | remove: 'Canapé' }}</span>\n</label>\n{% endif %}{% endfor %}\n</div>\n<div class=\"cbundle__step\">2 · Elige la medida</div>\n<select class=\"cbundle__size\"><option value>Selecciona medida…</option></select>\n<p class=\"cbundle__note\" hidden></p>\n<button type=\"button\" class=\"button cbundle__add\" disabled>Añadir al carrito</button>\n<a href=\"/cart\" class=\"cbundle__cart\" hidden>Ver carrito &rarr;</a>\n<script>(function(){var s=document.currentScript,box=s.closest('.cbundle');if(!box)return;var colchon=[];try{colchon=JSON.parse(box.getAttribute('data-colchon-variants')||'[]');}catch(e){}var radios=box.querySelectorAll('input[name=\"cbundle-canape\"]'),sizeSel=box.querySelector('.cbundle__size'),note=box.querySelector('.cbundle__note'),addBtn=box.querySelector('.cbundle__add'),cartLink=box.querySelector('.cbundle__cart');function ps(x){var m=(x||'').match(/\\d+/g);return (m&&m.length>=2)?m[0]+'x'+m[1]:null;}function selCan(){for(var i=0;i<radios.length;i++){if(radios[i].checked)return radios[i];}return radios[0];}function upd(){var r=selCan();if(!r)return;var cv=[];try{cv=JSON.parse(r.getAttribute('data-variants')||'[]');}catch(e){}var cm={};colchon.forEach(function(v){var k=ps(v.t);if(k)cm[k]=v.id;});sizeSel.innerHTML='<option value>Selecciona medida…</option>';cv.forEach(function(x){var k=ps(x.t);if(k&&cm[k]){var o=document.createElement('option');o.value=k;o.textContent=x.t;o.setAttribute('data-col',cm[k]);o.setAttribute('data-can',x.id);o.setAttribute('data-price',x.p||'');sizeSel.appendChild(o);}});note.hidden=true;addBtn.disabled=true;}sizeSel.addEventListener('change',function(){var o=sizeSel.options[sizeSel.selectedIndex];if(o&&o.value){addBtn.disabled=false;var p=o.getAttribute('data-price');if(p){note.hidden=false;note.textContent='Canapé '+p+' · y un 10% en tu colchón al comprarlos juntos.';}}else{addBtn.disabled=true;note.hidden=true;}});for(var i=0;i<radios.length;i++){radios[i].addEventListener('change',upd);}addBtn.addEventListener('click',function(){var o=sizeSel.options[sizeSel.selectedIndex];if(!o||!o.value)return;var col=o.getAttribute('data-col'),can=o.getAttribute('data-can');addBtn.disabled=true;var t=addBtn.textContent;addBtn.textContent='Añadiendo...';fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:[{id:Number(col),quantity:1},{id:Number(can),quantity:1}]})}).then(function(r){return r.json();}).then(function(){addBtn.textContent='✓ Añadidos al carrito';if(window.dormiToast)window.dormiToast('Colchón + canapé añadidos · 10% aplicado',{icon:'🎁'});if(cartLink)cartLink.hidden=false;fetch('/cart.js').then(function(r){return r.json();}).then(function(c){var b=document.querySelector('.cart-count-bubble span');if(b)b.textContent=c.item_count;}).catch(function(){});}).catch(function(){addBtn.disabled=false;addBtn.textContent=t;});});upd();})();</script>\n</div>"
          }
