{{ 'section-trust-signals.css' | asset_url | stylesheet_tag }}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="trust-signals page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="trust-signals__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.show_rating -%}
      <div class="trust-signals__rating">
        <span class="trust-signals__stars" aria-hidden="true">★★★★★</span>
        <span class="trust-signals__rating-text">
          <strong>{{ section.settings.rating_score }}</strong>/5 · {{ section.settings.rating_count }}
        </span>
      </div>
    {%- endif -%}

    <div class="trust-signals__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'badge' -%}
          <div class="trust-signals__item" {{ block.shopify_attributes }}>
            <span class="trust-signals__icon" aria-hidden="true">{{ block.settings.emoji }}</span>
            <p class="trust-signals__title">{{ block.settings.title }}</p>
            {%- if block.settings.text != blank -%}
              <p class="trust-signals__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_payments -%}
      <div class="trust-signals__pay">
        <span class="trust-signals__pay-label">🔒 {{ section.settings.payment_text }}</span>
        <div class="trust-signals__pay-icons">
          {%- assign methods = shop.enabled_payment_types -%}
          {%- if methods.size > 0 -%}
            {%- for type in methods -%}
              {{ type | payment_type_svg_tag: class: 'trust-signals__pay-icon' }}
            {%- endfor -%}
          {%- else -%}
            <span class="trust-signals__pay-fallback">Visa · Mastercard · PayPal · Bizum</span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Señales de confianza",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Miles de personas ya duermen mejor" },
    { "type": "checkbox", "id": "show_rating", "label": "Mostrar valoración", "default": true },
    { "type": "text", "id": "rating_score", "label": "Nota media", "default": "4,8" },
    { "type": "text", "id": "rating_count", "label": "Texto de reseñas", "default": "basado en +1.200 reseñas verificadas" },
    { "type": "checkbox", "id": "show_payments", "label": "Mostrar pago seguro", "default": true },
    { "type": "text", "id": "payment_text", "label": "Texto de pago", "default": "Pago 100% seguro y cifrado" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-2" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado superior", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado inferior", "default": 48 }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Sello de confianza",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Icono (emoji)", "default": "🌙" },
        { "type": "text", "id": "title", "label": "Título", "default": "30 noches de prueba" },
        { "type": "text", "id": "text", "label": "Texto", "default": "Devolución gratuita" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Señales de confianza",
      "blocks": [
        { "type": "badge", "settings": { "emoji": "🌙", "title": "30 noches de prueba", "text": "Devolución gratis si no te convence" } },
        { "type": "badge", "settings": { "emoji": "🛡️", "title": "3 años de garantía", "text": "Respaldamos su durabilidad" } },
        { "type": "badge", "settings": { "emoji": "🚚", "title": "Envío gratis 24-72h", "text": "Con seguimiento a tu casa" } },
        { "type": "badge", "settings": { "emoji": "💳", "title": "Paga a plazos", "text": "Financiación sin intereses" } },
        { "type": "badge", "settings": { "emoji": "🇪🇺", "title": "Fabricación europea", "text": "Materiales certificados" } },
        { "type": "badge", "settings": { "emoji": "↩️", "title": "Recogida gratuita", "text": "Sin tener que empaquetar nada" } }
      ]
    }
  ]
}
{% endschema %}
