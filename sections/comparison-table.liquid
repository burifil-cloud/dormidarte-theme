{{ 'section-comparison-table.css' | asset_url | stylesheet_tag }}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="comparison page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="comparison__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="comparison__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="comparison__table-wrap">
      <table class="comparison__table">
        <thead>
          <tr>
            <th class="comparison__feature-head"></th>
            <th class="comparison__us">{{ section.settings.us_label }}</th>
            <th class="comparison__them">{{ section.settings.them_label }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            {%- if block.type == 'row' -%}
              <tr {{ block.shopify_attributes }}>
                <td class="comparison__feature">{{ block.settings.feature }}</td>
                <td class="comparison__cell comparison__cell--us">
                  {%- if block.settings.us_text != blank -%}
                    <span class="comparison__check">✓</span> {{ block.settings.us_text }}
                  {%- else -%}
                    <span class="comparison__check">✓</span>
                  {%- endif -%}
                </td>
                <td class="comparison__cell comparison__cell--them">
                  {%- if block.settings.them_text != blank -%}
                    {{ block.settings.them_text }}
                  {%- else -%}
                    <span class="comparison__cross">✕</span>
                  {%- endif -%}
                </td>
              </tr>
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Tabla comparativa",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "¿Por qué comprar en Dormidarte?" },
    { "type": "text", "id": "subheading", "label": "Subtítulo", "default": "La misma calidad que las grandes marcas, sin pagar de más." },
    { "type": "text", "id": "us_label", "label": "Columna nosotros", "default": "Dormidarte" },
    { "type": "text", "id": "them_label", "label": "Columna comparación", "default": "Tienda tradicional" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado superior", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado inferior", "default": 48 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Fila",
      "settings": [
        { "type": "text", "id": "feature", "label": "Característica", "default": "Precio justo" },
        { "type": "text", "id": "us_text", "label": "Nosotros (texto opcional)", "info": "Vacío = solo ✓" },
        { "type": "text", "id": "them_text", "label": "Comparación (texto opcional)", "info": "Vacío = ✕" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabla comparativa",
      "blocks": [
        { "type": "row", "settings": { "feature": "Precio", "us_text": "Precio de fábrica", "them_text": "Con sobreprecio" } },
        { "type": "row", "settings": { "feature": "Prueba en casa", "us_text": "30 noches", "them_text": "Sin prueba" } },
        { "type": "row", "settings": { "feature": "Garantía", "us_text": "3 años", "them_text": "2 años" } },
        { "type": "row", "settings": { "feature": "Envío", "us_text": "Gratis 24-72h", "them_text": "De pago / lento" } },
        { "type": "row", "settings": { "feature": "Materiales premium", "us_text": "", "them_text": "Varía" } },
        { "type": "row", "settings": { "feature": "Devolución gratuita", "us_text": "", "them_text": "" } },
        { "type": "row", "settings": { "feature": "Pago a plazos", "us_text": "Sin intereses", "them_text": "No siempre" } }
      ]
    }
  ]
}
{% endschema %}
