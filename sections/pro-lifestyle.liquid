{{ 'section-pro-lifestyle.css' | asset_url | stylesheet_tag }}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="pro-life page-width section-{{ section.id }}-padding">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="pro-life__head">
        {%- if section.settings.eyebrow != blank -%}<span class="pro-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="pro-life__heading">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="pro-life__sub">{{ section.settings.subheading }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="pro-life__rows">
      {%- for block in section.blocks -%}
        <div class="pro-life__row" {{ block.shopify_attributes }}>
          <div class="pro-life__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 58vw, 100vw', widths: '500, 800, 1100, 1400, 1600', class: 'pro-life__img' }}
            {%- elsif block.settings.image_asset != blank -%}
              <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ block.settings.title | escape }}" class="pro-life__img" loading="lazy" width="2250" height="1500">
            {%- endif -%}
          </div>
          <div class="pro-life__text">
            {%- if block.settings.kicker != blank -%}<span class="pro-life__kicker">{{ block.settings.kicker }}</span>{%- endif -%}
            {%- if block.settings.title != blank -%}<h3 class="pro-life__title">{{ block.settings.title }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<div class="pro-life__body rte">{{ block.settings.text }}</div>{%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Galería en dormitorio",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Antetítulo" },
    { "type": "text", "id": "heading", "label": "Título", "default": "En tu dormitorio" },
    { "type": "text", "id": "subheading", "label": "Subtítulo" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado superior", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado inferior", "default": 64 }
  ],
  "blocks": [
    {
      "type": "scene",
      "name": "Escena",
      "settings": [
        { "type": "text", "id": "image_asset", "label": "Nombre de imagen en assets", "info": "Ej: life-carbon-1.jpg" },
        { "type": "image_picker", "id": "image", "label": "Imagen (opcional, desde archivos)" },
        { "type": "text", "id": "kicker", "label": "Etiqueta pequeña" },
        { "type": "text", "id": "title", "label": "Título" },
        { "type": "richtext", "id": "text", "label": "Texto" }
      ]
    }
  ],
  "presets": [
    { "name": "Galería en dormitorio" }
  ]
}
{% endschema %}
