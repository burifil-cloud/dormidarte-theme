{{ 'section-pro-features.css' | asset_url | stylesheet_tag }}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="pro-features page-width section-{{ section.id }}-padding">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="pro-features__head">
        {%- if section.settings.eyebrow != blank -%}<span class="pro-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="pro-features__heading">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="pro-features__sub">{{ section.settings.subheading }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="pro-features__grid pro-features__grid--{{ section.settings.layout }}" style="--cols: {{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        <div class="pro-features__item" {{ block.shopify_attributes }}>
          <span class="pro-features__icon">{% render 'pro-icon', name: block.settings.icon %}</span>
          <div class="pro-features__text">
            <p class="pro-features__title">{{ block.settings.title }}</p>
            {%- if block.settings.text != blank -%}<p class="pro-features__desc">{{ block.settings.text }}</p>{%- endif -%}
            {%- if block.settings.icon == 'card' -%}
              <span class="pro-features__pays">
                <span class="pay-chip pay-chip--klarna">Klarna</span>
                <span class="pay-chip pay-chip--pepper">pepper</span>
              </span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Características (iconos)",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Antetítulo" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Por qué elegir Dormidarte" },
    { "type": "text", "id": "subheading", "label": "Subtítulo" },
    {
      "type": "select", "id": "layout", "label": "Formato",
      "options": [
        { "value": "bar", "label": "Barra horizontal" },
        { "value": "cards", "label": "Tarjetas" }
      ],
      "default": "cards"
    },
    { "type": "range", "id": "columns", "min": 2, "max": 4, "step": 1, "label": "Columnas", "default": 4 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado superior", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado inferior", "default": 56 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Característica",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icono",
          "options": [
            { "value": "moon", "label": "Luna" },
            { "value": "truck", "label": "Camión" },
            { "value": "shield", "label": "Escudo" },
            { "value": "refresh", "label": "Devolución" },
            { "value": "card", "label": "Tarjeta" },
            { "value": "lock", "label": "Candado" },
            { "value": "star", "label": "Estrella" },
            { "value": "leaf", "label": "Hoja" },
            { "value": "thermometer", "label": "Temperatura" },
            { "value": "ruler", "label": "Regla" },
            { "value": "layers", "label": "Capas" },
            { "value": "clock", "label": "Reloj" },
            { "value": "check-circle", "label": "Check" },
            { "value": "headset", "label": "Atención" },
            { "value": "medal", "label": "Medalla" },
            { "value": "feather", "label": "Pluma" },
            { "value": "coil", "label": "Muelle" },
            { "value": "sparkle", "label": "Brillo" },
            { "value": "tag", "label": "Etiqueta" }
          ],
          "default": "check-circle"
        },
        { "type": "text", "id": "title", "label": "Título", "default": "Ventaja" },
        { "type": "text", "id": "text", "label": "Descripción" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Características (iconos)",
      "blocks": [
        { "type": "feature", "settings": { "icon": "moon", "title": "30 noches de prueba", "text": "Devolución gratis si no te convence" } },
        { "type": "feature", "settings": { "icon": "truck", "title": "Envío gratis 24-72h", "text": "Con seguimiento a tu casa" } },
        { "type": "feature", "settings": { "icon": "shield", "title": "3 años de garantía", "text": "Respaldamos su durabilidad" } },
        { "type": "feature", "settings": { "icon": "card", "title": "Paga a plazos", "text": "Financiación sin intereses" } }
      ]
    }
  ]
}
{% endschema %}
