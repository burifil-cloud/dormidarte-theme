{{ 'section-pro-lifestyle.css' | asset_url | stylesheet_tag }}

{%- comment -%} Lifestyle que usa las fotos del propio producto (ambiente). Para drops/liquidación. {%- endcomment -%}
{%- assign imgs = product.images -%}
{%- if imgs.size > 1 -%}
  <div class="color-{{ section.settings.color_scheme }} gradient">
    <div class="pro-life page-width section-{{ section.id }}-padding">
      <div class="pro-life__head">
        {%- if section.settings.eyebrow != blank -%}<span class="pro-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="pro-life__heading">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p class="pro-life__sub">{{ section.settings.subheading }}</p>{%- endif -%}
      </div>
      <div class="pro-life__rows">
        {%- assign captions = section.settings.captions | split: '|' -%}
        {%- assign shown = 0 -%}
        {%- for image in imgs -%}
          {%- if forloop.first -%}{%- continue -%}{%- endif -%}
          {%- if shown >= section.settings.max_photos -%}{%- break -%}{%- endif -%}
          <div class="pro-life__row">
            <div class="pro-life__media">
              <img class="pro-life__img" src="{{ image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" width="900" height="600" loading="lazy">
            </div>
            <div>
              <span class="pro-life__kicker">{{ section.settings.eyebrow | default: 'En tu dormitorio' }}</span>
              <h3 class="pro-life__title">{{ captions[shown] | default: 'Descanso premium en casa' }}</h3>
              <p class="pro-life__body">{{ section.settings.body_text }}</p>
            </div>
          </div>
          {%- assign shown = shown | plus: 1 -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% style %}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "En tu dormitorio (fotos)",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "paragraph", "content": "Muestra las fotos de ambiente del propio producto (de la 2ª en adelante). Sube esas fotos en el producto." },
    { "type": "text", "id": "eyebrow", "label": "Antetítulo", "default": "Cómo queda en casa" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Así queda en tu dormitorio" },
    { "type": "text", "id": "subheading", "label": "Subtítulo", "default": "Descanso premium que además viste tu habitación." },
    { "type": "text", "id": "captions", "label": "Títulos por foto (separa con |)", "default": "Descanso que se nota|Diseño que combina" },
    { "type": "textarea", "id": "body_text", "label": "Texto bajo cada foto", "default": "Un colchón pensado para verse y sentirse de lujo en tu dormitorio." },
    { "type": "range", "id": "max_photos", "min": 1, "max": 4, "step": 1, "label": "Nº de fotos a mostrar", "default": 2 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-2" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado superior", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado inferior", "default": 56 }
  ],
  "presets": [ { "name": "En tu dormitorio (fotos)" } ]
}
{% endschema %}
