{{ 'section-home-hero.css' | asset_url | stylesheet_tag }}

{%- assign secs = section.settings.interval | default: 6 -%}
<div
  id="HeroSlider-{{ section.id }}"
  class="home-hero home-hero--slider color-{{ section.settings.color_scheme }}"
  style="--hero-min-height: {{ section.settings.height }}vh;"
  data-hero-slider
  data-interval="{{ secs | times: 1000 }}"
>
  <div class="home-hero__slides">
    {%- for block in section.blocks -%}
      {%- liquid
        assign img = block.settings.image_asset
        assign has_picker = false
        if block.settings.image != blank
          assign has_picker = true
        endif
        assign eager = false
        if forloop.first
          assign eager = true
        endif
      -%}
      <div class="home-hero__slide{% if forloop.first %} is-active{% endif %}" data-slide {{ block.shopify_attributes }}>
        <div class="home-hero__media">
          {%- if has_picker -%}
            {{
              block.settings.image
              | image_url: width: 3000
              | image_tag:
                loading: 'eager',
                sizes: '100vw',
                widths: '600, 900, 1200, 1600, 2000, 2600, 3000',
                class: 'home-hero__img'
            }}
          {%- elsif img != blank -%}
            <img
              src="{{ img | asset_url }}"
              alt="{{ block.settings.heading | escape }}"
              class="home-hero__img"
              {% if eager %}loading="eager"{% else %}loading="lazy"{% endif %}
              width="2250"
              height="1500"
            >
          {%- endif -%}
          <div class="home-hero__overlay" style="opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>
        </div>
        <div class="home-hero__inner page-width">
          <div class="home-hero__content home-hero__content--{{ block.settings.content_alignment }}">
            {%- if block.settings.eyebrow != blank -%}
              <p class="home-hero__eyebrow">{{ block.settings.eyebrow }}</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="home-hero__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <div class="home-hero__subheading rte">{{ block.settings.subheading }}</div>
            {%- endif -%}
            <div class="home-hero__buttons">
              {%- if block.settings.button_1_label != blank -%}
                <a href="{{ block.settings.button_1_link | default: '#' }}" class="button button--primary">{{ block.settings.button_1_label }}</a>
              {%- endif -%}
              {%- if block.settings.button_2_label != blank -%}
                <a href="{{ block.settings.button_2_link | default: '#' }}" class="button button--secondary home-hero__button-2">{{ block.settings.button_2_label }}</a>
              {%- endif -%}
            </div>
            {%- if block.settings.show_pay -%}
              <div class="home-hero__pays">
                <span class="hpay-lead">Paga a plazos:</span>
                <span class="hpay hpay--klarna">Klarna</span>
                <span class="hpay hpay--pepper">pepper</span>
                <span class="hpay">Visa</span>
                <span class="hpay">Mastercard</span>
                <span class="hpay">Bizum</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="home-hero__dots" data-dots>
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="home-hero__dot{% if forloop.first %} is-active{% endif %}"
          data-dot
          data-index="{{ forloop.index0 }}"
          aria-label="Ir a la hoja {{ forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.show_usp -%}
    <div class="home-hero__usp-wrap color-{{ section.settings.usp_color_scheme }}">
      <ul class="home-hero__usp page-width" role="list">
        <li><span aria-hidden="true">🌙</span> {{ section.settings.usp_1 }}</li>
        <li><span aria-hidden="true">🚚</span> {{ section.settings.usp_2 }}</li>
        <li><span aria-hidden="true">🛡️</span> {{ section.settings.usp_3 }}</li>
        <li><span aria-hidden="true">💳</span> {{ section.settings.usp_4 }}</li>
      </ul>
    </div>
  {%- endif -%}
</div>

<script>
  (function () {
    var root = document.getElementById('HeroSlider-{{ section.id }}');
    if (!root) return;
    var slides = [].slice.call(root.querySelectorAll('[data-slide]'));
    var dots = [].slice.call(root.querySelectorAll('[data-dot]'));
    if (slides.length < 2) return;
    var i = 0;
    var interval = parseInt(root.getAttribute('data-interval'), 10) || 6000;
    var timer = null;
    function go(n) {
      slides[i].classList.remove('is-active');
      if (dots[i]) dots[i].classList.remove('is-active');
      i = (n + slides.length) % slides.length;
      slides[i].classList.add('is-active');
      if (dots[i]) dots[i].classList.add('is-active');
    }
    function start() { stop(); timer = setInterval(function () { go(i + 1); }, interval); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    dots.forEach(function (d, idx) {
      d.addEventListener('click', function () { go(idx); start(); });
    });
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    document.addEventListener('visibilitychange', function () { if (document.hidden) { stop(); } else { start(); } });
    if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) start();
  })();
</script>

{% schema %}
{
  "name": "Portada / Hero",
  "tag": "section",
  "class": "section section--hero",
  "max_blocks": 6,
  "settings": [
    {
      "type": "range",
      "id": "height",
      "min": 40,
      "max": 90,
      "step": 5,
      "unit": "vh",
      "label": "Altura",
      "default": 75
    },
    {
      "type": "range",
      "id": "interval",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "label": "Segundos por hoja",
      "default": 6
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color del texto",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Barra de ventajas (opcional)"
    },
    {
      "type": "checkbox",
      "id": "show_usp",
      "label": "Mostrar barra de ventajas",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "usp_color_scheme",
      "label": "Color de la barra",
      "default": "scheme-1"
    },
    { "type": "text", "id": "usp_1", "label": "Ventaja 1", "default": "30 noches de prueba" },
    { "type": "text", "id": "usp_2", "label": "Ventaja 2", "default": "Envío gratis 24-72h" },
    { "type": "text", "id": "usp_3", "label": "Ventaja 3", "default": "3 años de garantía" },
    { "type": "text", "id": "usp_4", "label": "Ventaja 4", "default": "Paga a plazos" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Hoja",
      "settings": [
        {
          "type": "text",
          "id": "image_asset",
          "label": "Nombre de imagen en assets",
          "info": "Ej: life-carbon-1.jpg (ya subida al tema). Si eliges una imagen abajo, esa tiene prioridad.",
          "default": "hero-blu.jpg"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen (opcional, desde archivos)"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "label": "Oscurecer imagen",
          "default": 40
        },
        {
          "type": "select",
          "id": "content_alignment",
          "options": [
            { "value": "left", "label": "Izquierda" },
            { "value": "center", "label": "Centro" }
          ],
          "default": "left",
          "label": "Alineación del texto"
        },
        { "type": "text", "id": "eyebrow", "label": "Texto superior", "default": "Colchones premium · Precio justo" },
        { "type": "text", "id": "heading", "label": "Título", "default": "Duerme mejor desde la primera noche" },
        {
          "type": "richtext",
          "id": "subheading",
          "label": "Subtítulo",
          "default": "<p>Colchones de fabricación europea con materiales de alta gama, al mejor precio.</p>"
        },
        { "type": "text", "id": "button_1_label", "label": "Botón 1 · texto", "default": "Ver colchones" },
        { "type": "url", "id": "button_1_link", "label": "Botón 1 · enlace" },
        { "type": "text", "id": "button_2_label", "label": "Botón 2 · texto", "default": "Encuentra tu colchón" },
        { "type": "url", "id": "button_2_link", "label": "Botón 2 · enlace" },
        { "type": "checkbox", "id": "show_pay", "label": "Mostrar medios de pago (Klarna, Pepper…)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Portada / Hero",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
