{{ 'section-showcase-cards.css' | asset_url | stylesheet_tag }}

<div class="klc color-{{ section.settings.color_scheme }}">
  <div class="klc__wrap page-width section-{{ section.id }}-padding">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="klc__head">
        {%- if section.settings.eyebrow != blank -%}<p class="klc__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="klc__heading">{{ section.settings.heading }}{% if section.settings.heading_sub != blank %} <span class="klc__heading-sub">{{ section.settings.heading_sub }}</span>{% endif %}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="klc__row">
      {%- for block in section.blocks -%}
        {%- liquid
          assign p = all_products[block.settings.product]
          assign url = block.settings.link
          if url == blank and p != blank
            assign url = p.url
          endif
          assign label = block.settings.label
          if label == blank and p != blank
            assign label = p.title
          endif
        -%}
        <a class="klc__card" href="{{ url | default: '#' }}" {{ block.shopify_attributes }}>
          <span class="klc__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'klc__img', alt: label | escape }}
            {%- elsif block.settings.image_asset != blank -%}
              <img class="klc__img" src="{{ block.settings.image_asset | asset_url }}" alt="{{ label | escape }}" loading="lazy" width="600" height="800">
            {%- elsif p.featured_image != blank -%}
              <img class="klc__img" src="{{ p.featured_image | image_url: width: 900 }}" alt="{{ label | escape }}" loading="lazy" width="600" height="800">
            {%- endif -%}
          </span>
          {%- if block.settings.badge != blank -%}<span class="klc__badge">{{ block.settings.badge }}</span>{%- endif -%}
          {%- if label != blank -%}<span class="klc__label">{{ label }}</span>{%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% style %}
  .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px; padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px; }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Escaparate visual",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Antetítulo" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Diseñados para tu mejor descanso." },
    { "type": "text", "id": "heading_sub", "label": "Título · parte en gris" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Esquema de color", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado superior", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espaciado inferior", "default": 48 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Tarjeta",
      "settings": [
        { "type": "product", "id": "product", "label": "Producto (para foto, nombre y enlace)" },
        { "type": "image_picker", "id": "image", "label": "Imagen (opcional, desde archivos)" },
        { "type": "text", "id": "image_asset", "label": "Imagen (assets)", "info": "Ej: life-carbon-1.jpg" },
        { "type": "text", "id": "label", "label": "Etiqueta (por defecto: nombre del producto)" },
        { "type": "text", "id": "badge", "label": "Insignia (opcional)", "info": "Ej: Oferta" },
        { "type": "url", "id": "link", "label": "Enlace (por defecto: el del producto)" }
      ]
    }
  ],
  "presets": [
    { "name": "Escaparate (estilo Klarna)" }
  ]
}
{% endschema %}
