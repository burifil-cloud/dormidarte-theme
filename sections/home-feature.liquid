{{ 'section-home-feature.css' | asset_url | stylesheet_tag }}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="home-feature page-width section-{{ section.id }}-padding home-feature--{{ section.settings.image_position }}">
    <div class="home-feature__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 50vw, 100vw', widths: '400, 600, 800, 1000, 1200, 1600', class: 'home-feature__img' }}
      {%- elsif section.settings.image_asset != blank -%}
        <img
          src="{{ section.settings.image_asset | asset_url }}"
          alt="{{ section.settings.heading | escape }}"
          class="home-feature__img"
          loading="lazy"
          width="2250"
          height="1500"
        >
      {%- endif -%}
    </div>
    <div class="home-feature__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="home-feature__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="home-feature__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="home-feature__body rte">{{ section.settings.text }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="button button--primary">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Imagen + texto (a medida)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "image_asset",
      "label": "Nombre de imagen en assets",
      "info": "Ej: feature-dream.jpg. Si eliges una imagen abajo, esa tiene prioridad.",
      "default": "feature-dream.jpg"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (opcional, desde archivos)"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        { "value": "left", "label": "Imagen a la izquierda" },
        { "value": "right", "label": "Imagen a la derecha" }
      ],
      "default": "left",
      "label": "Posición de la imagen"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Calidad premium"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Materiales de alta gama, a un precio justo"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Fabricamos con espumas de alta densidad, viscoelástica adaptable y tejidos transpirables. La misma calidad de las grandes marcas, sin pagar de más.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Botón · texto",
      "default": "Descubrir la gama"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Botón · enlace"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 48
    }
  ],
  "presets": [
    { "name": "Imagen + texto (a medida)" }
  ]
}
{% endschema %}
